{% extends 'base.html.twig' %}

{% block title %}Mes articles{% endblock %}

{% block body %}
<div class="main-type">
    <h1>Profil : mes articles</h1>

    {% if articles | length == 0 %}
        <p class="info" style="margin-top: 15px;">Vous n'avez pas encore d'article à afficher ici.</p>
    {% else %}
        <p class="mini" style="margin-top: 15px;">{{ total }} article{{ total > 1 ? 's' : '' }}</p>
    {% endif %}

    {% for article in articles %}
        <div class="article-tools">
            {# Article status #}
            {% if article.status == constant('App\\Entity\\Article::STATUS_PUBLISHED') %}
                <p class="info">Publié : cet article est en ligne</p>
            {% elseif article.status == constant('App\\Entity\\Article::STATUS_REFUSED') %}
                <p class="erreur">Désactivé : cet article a été refusé par les responsables de commission</p>
            {% elseif article.topubly == 0 %}
                <p class="draft">Brouillon (non publié)</p>
            {% elseif article.status == constant('App\\Entity\\Article::STATUS_PENDING') and article.topubly == 1 %}
                <p class="alerte">En attente : cet article n'a pas encore été publié par les responsables de commission</p>
            {% endif %}

            {# Action buttons #}
            {% if article.status == constant('App\\Entity\\Article::STATUS_PUBLISHED') %}
                <a href="/article/{{ article.code }}-{{ article.id }}" title="Voir l'article" class="nice2">
                    Voir
                </a>
            {% else %}
                <a href="/article/{{ article.code }}-{{ article.id }}?forceshow=true" title="Aperçu de l'article" class="nice2">
                    Aperçu
                </a>
            {% endif %}

            <a href="/article/edit/{{ article.id }}" title="Modifier l'article" class="nice2 orange">
                Modifier
            </a>

            {% if article.status == constant('App\\Entity\\Article::STATUS_PUBLISHED') %}
                <a href="javascript:void(0);" onclick="document.getElementById('depublier-form-{{ article.id }}').style.display='block';" title="Dépublier l'article" class="nice2 red" id="button-depublier-{{ article.id }}">
                    Dépublier
                </a>
            {% else %}
                <a href="javascript:void(0);" onclick="document.getElementById('supprimer-form-{{ article.id }}').style.display='block';" title="Supprimer l'article" class="nice2 red">
                    Supprimer
                </a>
            {% endif %}

            <br style="clear:both" />
        </div>

        <div class="encart_article">
            {# Article image #}
            {% if article.mediaUpload %}
                <a href="/article/{{ article.code }}-{{ article.id }}" title="Voir cet article" class="illustration fader" style="background-image:url('{{ media_thumbnail(article.mediaUpload, 'min_thumbnail') }}')"></a>
            {% else %}
                <a href="/article/{{ article.code }}-{{ article.id }}" title="Voir cet article" class="illustration fader" style="background-image:url('');"></a>
            {% endif %}

            {# Article title #}
            <h2>
                <a href="/article/{{ article.code }}-{{ article.id }}" title="Voir cet article">
                    {{ article.titre }}
                </a>
            </h2>

            {# Article commission and date #}
            <p class="commission-title">
                {% if article.validationDate %}
                    {{ article.validationDate|date('d/m/Y') }} -
                {% endif %}

                {% if article.commission %}
                    <a href="/commission/{{ article.commission.code }}" title="Toutes les actus de cette commission">
                        {{ article.commission.title }}
                    </a>
                {% elseif article.evt and article.evt.commission %}
                    <a href="/sortie/{{ article.evt.code }}-{{ article.evt.id }}" title="Voir la sortie liée à cet article : « {{ article.evt.titre }} »">
                        compte rendu de sortie
                    </a>
                {% else %}
                    <a href="/" title="Toutes les actus du club">
                        CLUB
                    </a>
                {% endif %}
            </p>

            {# Article summary #}
            <p class="summup">
                {{ article.cont|striptags|slice(0, 170) }}{% if article.cont|length > 170 %}...{% endif %}
                <a href="/article/{{ article.code }}-{{ article.id }}" title="Voir cet article">
                    [...]
                </a>
            </p>
            <br style="clear:both" />
        </div>

        {# Unpublish form (hidden) #}
        {% if article.status == constant('App\\Entity\\Article::STATUS_PUBLISHED') %}
            <div id="depublier-form-{{ article.id }}" style="display:none; margin-bottom: 20px; padding: 20px; background-color: #f0f0f0; border-radius: 4px;">
                <form action="{{ path('profil_articles') }}" method="post" style="text-align:left">
                    <input type="hidden" name="operation" value="article_depublier" />
                    <input type="hidden" name="id_article" value="{{ article.id }}" />
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('article_depublier') }}" />
                    <p>Voulez-vous vraiment retirer cet article du site ? Il repassera en "Brouillon" et vous devrez à nouveau le faire publier par un responsable si vous désirez le publier à nouveau.</p>
                    <input type="button" class="nice2" value="Annuler" onclick="document.getElementById('depublier-form-{{ article.id }}').style.display='none';" />
                    <input type="submit" class="nice2 orange" value="Dépublier mon article" />
                </form>
            </div>
        {% else %}
            <div id="supprimer-form-{{ article.id }}" style="display:none; margin-bottom: 20px; padding: 20px; background-color: #f0f0f0; border-radius: 4px;">
                <form action="{{ path('profil_articles') }}" method="post" style="text-align:left">
                    <input type="hidden" name="operation" value="article_del" />
                    <input type="hidden" name="id_article" value="{{ article.id }}" />
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('article_del') }}" />
                    <p>Voulez-vous vraiment supprimer définitivement cet article ? <br />Cette action est irréversible.</p>
                    <input type="button" class="nice2" value="Annuler" onclick="document.getElementById('supprimer-form-{{ article.id }}').style.display='none';" />
                    <input type="submit" class="nice2 red" value="Supprimer mon article" />
                </form>
            </div>
        {% endif %}

        <br /><br />
    {% endfor %}

    {# Pagination #}
    {% if total > per_page %}
        <hr /><nav class="pageSelect">
        {% for i in 1..pages %}
            <a href="{{ path('profil_articles') }}?page={{ i }}" title="" class="{{ page == i ? 'up' : '' }}">p{{ i }}</a> {{ i < pages ? ' ' : '' }}
        {% endfor %}
        </nav>
    {% endif %}
</div>
{% endblock %}
